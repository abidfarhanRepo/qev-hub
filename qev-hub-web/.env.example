# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Test Mode Configuration
# Enable automatic order status progression for development/testing
# WARNING: MUST be set to "false" in production
NEXT_PUBLIC_TEST_MODE=true

# Note: OpenStreetMap and CartoDB are used for maps - NO API KEY REQUIRED
# Map tiles are served for free from these servers
